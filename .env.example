# Excel MCP Server Configuration
# Copy this file to .env and modify as needed

# Server Configuration
MCP_SERVER_NAME=excel-mcp
MCP_SERVER_VERSION=1.0.0
MCP_LOG_LEVEL=info

# Permission Configuration
# Comma-separated list of allowed paths (empty = all paths allowed except denied)
MCP_ALLOWED_PATHS=

# Comma-separated list of denied paths (higher priority than allowed)
MCP_DENIED_PATHS=/etc/*,/sys/*,/proc/*,C:\Windows\*,C:\Program Files\*

# Maximum file size in bytes (default: 50MB)
MCP_MAX_FILE_SIZE=52428800

# Full permissions configuration as JSON (overrides individual settings above)
# MCP_PERMISSIONS_CONFIG={"allowedPaths":[],"deniedPaths":[],"maxFileSize":52428800,"allowedExtensions":[".xlsx",".xls"],"permissions":["read","write"]}